# ============================================
# 课前故事视频生成器 - 环境变量配置
# ============================================
# 复制此文件为 .env，填入实际 API Key

# ---------- MiniMax ----------
# MiniMax API Key（从 MiniMax 开放平台获取）
MINIMAX_API_KEY=your_minimax_api_key_here

# MiniMax API 地址（通常不需要修改）
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# MiniMax 模型名称（根据申请到的模型填写）
MINIMAX_MODEL=MiniMax-Text-01

# ---------- 豆包 SeedAce 2.0 ----------
# SeedAce API Key（从火山引擎开放平台获取）
SEEDACE_API_KEY=your_seedace_api_key_here

# SeedAce API 地址（通常不需要修改）
SEEDACE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# SeedAce 模型名称
SEEDACE_MODEL=seedance-2.0

# ---------- 视频参数 ----------
# 视频最大时长（秒），范围 5-60
VIDEO_DURATION=60

# 视频分辨率（720p / 1080p）
VIDEO_RESOLUTION=720p

# 视频宽高比（16:9 / 9:16 / 1:1）
VIDEO_ASPECT_RATIO=16:9

# ---------- 超时设置 ----------
# 故事生成超时（秒）
STORY_TIMEOUT=30

# 视频提交请求超时（秒）
VIDEO_SUBMIT_TIMEOUT=30

# 轮询间隔（秒）
VIDEO_POLL_INTERVAL=5

# 视频生成总超时（秒）
VIDEO_TOTAL_TIMEOUT=300

# ---------- 输出目录 ----------
# 输出文件存放目录
OUTPUT_DIR=output
